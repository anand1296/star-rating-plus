{
  "name": "star-rating-plus",
  "description": "A simple, flexible star rating component (React + Web Component) with hover color mapping and Tailwind-friendly styling.",
  "version": "1.0.2",
  "type": "module",
  "main": "dist/index.cjs.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs.js",
      "types": "./dist/index.d.ts"
    },
    "./web-component": {
      "import": "./dist/web-component/registerStar.js",
      "require": "./dist/web-component/registerStar.cjs.js",
      "types": "./dist/web-component/registerStar.d.ts"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "tsup",
    "build:css": "node ./scripts/build-css.cjs",
    "test": "jest --passWithNoTests --runInBand",
    "prepare": "",
    "preview": "vite preview"
  },
  "keywords": [
    "star",
    "rating",
    "webcomponent",
    "react",
    "tailwind"
  ],
  "author": "Your Name",
  "license": "MIT",
  "dependencies": {
    "@tailwindcss/vite": "^4.1.17",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/postcss": "^4.1.17",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^14.0.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^29.0.0",
    "@types/node": "^24.10.0",
    "@types/react": "^18.2.21",
    "@types/react-dom": "^18.2.7",
    "@vitejs/plugin-react": "^5.1.0",
    "autoprefixer": "^10.4.22",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jest": "^29.0.0",
    "jest-environment-jsdom": "^30.2.0",
    "postcss": "^8.5.6",
    "rimraf": "^5.0.0",
    "tailwindcss": "^4.1.17",
    "ts-jest": "^29.4.5",
    "tsup": "^6.0.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.3",
    "vite": "^7.2.2"
  }
}
